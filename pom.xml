      <groupId>com.google.cloud</groupId>
      <artifactId>google-cloud-dataflow</artifactId>
    </dependency>

    <!-- https://mvnrepository.com/artifact/com.google.cloud/google-cloud-secretmanager -->
    <dependency>
      <groupId>com.google.cloud</groupId>
      <artifactId>google-cloud-secretmanager</artifactId>
